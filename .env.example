# ============================================================
# ⚙️ ОСНОВНЫЕ НАСТРОЙКИ СИСТЕМЫ "ВИКС РАСПИСАНИЕ"
# ============================================================

# Токен вашего бота от @BotFather
BOT_TOKEN=

# Путь к файлу базы данных SQLite (внутри контейнера или локально)
DB_PATH=


# ============================================================
# 💬 НАСТРОЙКИ ТЕЛЕГРАМ-ЧАТОВ (ГРУПП)
# ============================================================

# ID группы, куда публикуются утвержденные наряды (кнопка "Отправить в группу")
# Чтобы узнать ID, добавьте в группу бота @myidbot (ID начинается с -100)
GROUP_CHAT_ID=

# ID группы для ежедневного автоматического отчета (план на завтра в 13:00)
# Можно указать тот же чат, что и выше, либо отдельный чат для руководства
REPORT_GROUP_ID=


# ============================================================
# 🔐 ПАРОЛИ ДЛЯ РЕГИСТРАЦИИ ПОЛЬЗОВАТЕЛЕЙ
# ============================================================
# Эти пароли сотрудники вводят один раз при первом запуске бота

# Пароль для роли: 👷‍♂️ Прораб
FOREMAN_PASS=

# Пароль для роли: 🛡 Модератор
MODERATOR_PASS=

# Пароль для роли: 👔 БОСС
BOSS_PASS=

# Пароль для роли: 👑 Супер-Админ
SUPERADMIN_PASS=


# ============================================================
# 🛡 ID РУКОВОДСТВА (ДЛЯ ПРЯМОГО ДОСТУПА И ЛОГОВ)
# ============================================================
# Укажите ваш личный Telegram ID (узнать можно в @getmyid_bot).
# Можно указать несколько ID через запятую без пробелов.

# Получают уведомления о действиях сотрудников + системные ошибки (Tracebacks)
SUPER_ADMIN_IDS=

# Получают только уведомления о действиях (кто зашел, кто создал/одобрил заявку)
BOSS_IDS=